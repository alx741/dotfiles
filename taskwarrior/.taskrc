#{{{ Files
    data.location=~/.task
#}}}

#{{{ Terminal
    editor=vim
#}}}

#{{{ Misc
    indent.annotation=4
    undo.style=diff
#}}}

#{{{ Dates
    weekstart=Monday
#}}}

#{{{ Color
    color=on
    include /usr/share/doc/task/rc/solarized-light-256.theme
    #include /usr/share/doc/task/rc/holidays.es-EC.rc
#}}}

#{{{ Sync
    taskd.server=task.demerzel.sillybytes.net:53599
    taskd.key=\/home\/alx\/.task\/alx.key.pem
    taskd.certificate=\/home\/alx\/.task\/alx.cert.pem
    taskd.ca=\/home\/alx\/.task\/ca.cert.pem
    taskd.credentials=none/alx/62ed1241-b34a-11ee-877a-6f0acefe97f0
#}}}


